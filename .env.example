NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# ─── Z-API (mesma instância do zapi-monitor) ───────────────────
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# Destino do relatório semanal.
# Fase 1 (teste): número do Luiz "5561981726782"
# Fase 2 (prod):  group id "120363xxxxx@g.us"
ZAPI_DESTINATION=5561981726782

# Se "true", monta a mensagem mas NÃO envia (loga no console). Útil em dev.
ZAPI_DRY_RUN=false

# ─── Cron / Auth ───────────────────────────────────────────────
# Token aleatório para autenticar chamadas ao /api/cron/*
# Vercel Cron envia automático no header Authorization. Gere com: openssl rand -hex 32
CRON_SECRET=

# ─── App ───────────────────────────────────────────────────────
# URL pública (Vercel preenche automático em prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000
